root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 140
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
ktlint_code_style = intellij_idea

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.xml]
indent_size = 4

[Makefile]
indent_style = tab

[*.gradle.kts]
indent_size = 4
