  {
    "id": "dist_poisson_mgf",
    "title": "MGF of the Poisson Distribution",
    "topic": "distribution_theory",
    "subtopic": "Poisson Distribution",
    "difficulty": "undergraduate",
    "statement": "\\text{If } X \\sim \\text{Poisson}(\\lambda), \\text{ then } M_X(t) = \\exp\\!\\left(\\lambda(e^t - 1)\\right)",
    "conclusion": "M_X(t) = \\exp\\!\\left(\\lambda(e^t - 1)\\right)",
    "tags": ["poisson", "MGF", "moment generating function", "discrete distribution"],
    "assumptions": ["X \\sim \\text{Poisson}(\\lambda)", "\\lambda > 0", "t \\in \\mathbb{R}"],
    "intuition": "The Poisson MGF reveals its exponential family structure and confirms E[X] = Var(X) = λ.",
    "pitfalls": [],
    "searchKeywords": ["poisson MGF", "poisson moment generating function", "lambda"],
    "relatedIds": ["dist_poisson_mean_variance"],
    "references": ["Hogg, R., McKean, J., Craig, A. (2019). Introduction to Mathematical Statistics. 8th ed."],
    "derivationSteps": [
      {
        "stepNumber": 1,
        "expression": "M_X(t) = \\mathbb{E}[e^{tX}] = \\sum_{k=0}^{\\infty} e^{tk} \\cdot \\frac{\\lambda^k e^{-\\lambda}}{k!}",
        "justification": "Definition of MGF for Discrete RV",
        "explanation": "For a discrete random variable, E[g(X)] = Σ g(k) P(X=k). Here g(k) = e^{tk} and P(X=k) = e^{-λ}λ^k/k!.",
        "ruleId": "definition",
        "assumptions": [],
        "hints": [],
        "substeps": []
      },
      {
        "stepNumber": 2,
        "expression": "= e^{-\\lambda} \\sum_{k=0}^{\\infty} \\frac{(\\lambda e^t)^k}{k!}",
        "justification": "Rearranging the Series",
        "explanation": "Factor out e^{-λ} and combine e^{tk}λ^k = (λe^t)^k.",
        "ruleId": "log_power",
        "assumptions": [],
        "hints": [],
        "substeps": []
      },
      {
        "stepNumber": 3,
        "expression": "= e^{-\\lambda} \\cdot e^{\\lambda e^t}",
        "justification": "Taylor Series of Exponential",
        "explanation": "The series Σ x^k/k! = e^x for x = λe^t. This is the Maclaurin series of the exponential function.",
        "ruleId": "definition",
        "assumptions": [],
        "hints": ["Recall: e^x = Σ_{k=0}^∞ x^k / k! for all x ∈ ℝ."],
        "substeps": []
      },
      {
        "stepNumber": 4,
        "expression": "= \\exp\\!\\left(\\lambda e^t - \\lambda\\right) = \\exp\\!\\left(\\lambda(e^t - 1)\\right)",
        "justification": "Combining Exponentials",
        "explanation": "e^{-λ} · e^{λe^t} = e^{λe^t - λ} = e^{λ(e^t - 1)} using the product rule for exponentials.",
        "ruleId": "exp_sum",
        "assumptions": [],
        "hints": [],
        "substeps": []
      }
    ],
    "examples": []
  },
