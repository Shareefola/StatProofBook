    "id": "dist_exponential_memoryless",
    "title": "Memoryless Property of the Exponential Distribution",
    "topic": "distribution_theory",
    "subtopic": "Exponential Distribution",
    "difficulty": "undergraduate",
    "statement": "\\text{If } X \\sim \\text{Exp}(\\lambda), \\text{ then } P(X > s + t \\mid X > s) = P(X > t)",
    "conclusion": "P(X > s + t \\mid X > s) = P(X > t)",
    "tags": ["exponential", "memoryless", "survival function"],
    "assumptions": ["X \\sim \\text{Exp}(\\lambda)", "\\lambda > 0", "s, t \\geq 0"],
    "intuition": "The exponential distribution has no memory: given survival past time s, the remaining lifetime has the same distribution as starting from scratch.",
    "pitfalls": ["This property is unique to the exponential among continuous distributions."],
    "searchKeywords": ["memoryless", "exponential distribution", "survival", "geometric"],
    "relatedIds": [],
    "references": [],
    "derivationSteps": [
      {
        "stepNumber": 1,
        "expression": "P(X > s + t \\mid X > s) = \\frac{P(X > s + t \\text{ and } X > s)}{P(X > s)} = \\frac{P(X > s + t)}{P(X > s)}",
        "justification": "Definition of Conditional Probability",
        "explanation": "Since s+t > s, the event {X > s+t} implies {X > s}, so their intersection is {X > s+t}.",
        "ruleId": "definition",
        "assumptions": [],
        "hints": [],
        "substeps": []
      },
      {
        "stepNumber": 2,
        "expression": "= \\frac{e^{-\\lambda(s+t)}}{e^{-\\lambda s}}",
        "justification": "Survival Function of Exp(λ)",
        "explanation": "For X ~ Exp(λ), the survival function is P(X > x) = e^{-λx}.",
        "ruleId": "definition",
        "assumptions": [],
        "hints": [],
        "substeps": []
      },
      {
        "stepNumber": 3,
        "expression": "= e^{-\\lambda(s+t) + \\lambda s} = e^{-\\lambda t}",
        "justification": "Laws of Exponents",
        "explanation": "e^{-λ(s+t)} / e^{-λs} = e^{-λ(s+t)-(-λs)} = e^{-λt}.",
        "ruleId": "power_product",
        "assumptions": [],
        "hints": [],
        "substeps": []
      },
      {
        "stepNumber": 4,
        "expression": "= P(X > t)",
        "justification": "Survival Function Recognition",
        "explanation": "e^{-λt} is exactly P(X > t) for an Exp(λ) random variable.",
        "ruleId": "definition",
        "assumptions": [],
        "hints": [],
        "substeps": []
      }
