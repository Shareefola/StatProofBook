<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme (Compose manages colors; this is for the Window) -->
    <style name="Theme.StatProof" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.StatProof.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#3F51B5</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.StatProof</item>
    </style>

</resources>
